# Hermes Web UI Configuration
# Copy to .env and customize

# Server port (production mode)
HERMES_WEB_PORT=8080

# JWT secret (auto-generated on first run if empty)
HERMES_WEB_JWT_SECRET=

# Default admin credentials (used on first run only)
HERMES_WEB_ADMIN_USER=admin
HERMES_WEB_ADMIN_PASS=

# Max concurrent agent instances
HERMES_WEB_MAX_AGENTS=8

# Path to hermes-agent project root (auto-detected if empty)
HERMES_AGENT_ROOT=

# HTTPS (production)
HERMES_WEB_HTTPS=true
HERMES_WEB_CERT_DIR=./certs
